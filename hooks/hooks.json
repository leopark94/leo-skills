{
  "$schema": "https://code.claude.com/hooks-schema.json",
  "_comment": "Leo Master Hooks — install.sh merges into ~/.claude/settings.json",

  "SessionStart": [
    {
      "matcher": "startup|resume",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/session-checklist.sh"
        }
      ]
    },
    {
      "matcher": "compact",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/compact-reinject.sh"
        }
      ]
    }
  ],

  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/prompt-guard.sh"
        }
      ]
    }
  ],

  "PreToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/detect-secrets.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/protect-files.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/ds-guard.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/no-console-log.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/no-sql-join.sh"
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/pre-commit-guard.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/dangerous-command-guard.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/detect-secrets.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/terraform-guard.sh"
        }
      ]
    },
    {
      "matcher": "Agent",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/agent-guard.sh"
        }
      ]
    }
  ],

  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/auto-format.sh"
        },
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/edit-tracker.sh"
        }
      ]
    }
  ],

  "Notification": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/notify.sh"
        }
      ]
    }
  ],

  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/utils/leo-skills/hooks/scripts/stop-loop-guard.sh"
        }
      ]
    }
  ]
}
